{
  "build": {
    "NAME": "headcar"
  },
  "include": [
    "$(MODDABLE)/examples/manifest_base.json",
    "$(MODDABLE)/examples/manifest_net.json",
    "$(MODDABLE)/modules/network/wifi/manifest.json",
    "$(MODDABLE)/modules/network/websocket/manifest.json",
    "$(MODDABLE)/modules/network/mdns/manifest.json",
    "$(MODDABLE)/modules/pins/digital/manifest.json",
    "$(MODDABLE)/modules/pins/pwm/manifest.json"
  ],
  "modules": {
    "*": "./main"
  },
  "config": {
    "ssid": "YOUR_WIFI_SSID",
    "password": "YOUR_WIFI_PASSWORD"
  },
  "platforms": {
    "esp32": {
      "modules": {
        "*": "./main"
      }
    }
  }
}
